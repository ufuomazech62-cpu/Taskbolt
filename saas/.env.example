# Taskbolt SaaS - Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE
# ============================================================================
# PostgreSQL connection string
DATABASE_URL="postgresql://taskbolt:taskbolt_dev_password@localhost:5432/taskbolt_saas?schema=public"

# Connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================================================
# REDIS
# ============================================================================
# Redis connection URL
REDIS_URL="redis://localhost:6379/0"

# ============================================================================
# FIREBASE
# ============================================================================
# Firebase project ID
FIREBASE_PROJECT_ID="taskbolt-dev"

# Path to Firebase service account JSON (for backend)
# Get this from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS_PATH="./firebase-credentials.json"

# Firebase Auth Emulator (for local development)
FIREBASE_AUTH_EMULATOR_HOST="localhost:9099"

# ============================================================================
# APPLICATION
# ============================================================================
# Server port
TASKBOLT_PORT=8088

# Debug mode (enables /docs, /redoc, etc.)
TASKBOLT_DEBUG=true

# CORS allowed origins (comma-separated)
TASKBOLT_CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Running in container (set to true when deployed)
TASKBOLT_RUNNING_IN_CONTAINER=false

# ============================================================================
# RATE LIMITING
# ============================================================================
# Enable rate limiting
RATE_LIMIT_ENABLED=true

# ============================================================================
# STRIPE
# ============================================================================
# Stripe API keys (test mode for development)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Stripe Price IDs for each plan
STRIPE_PRICE_STARTER="price_starter_monthly"
STRIPE_PRICE_PROFESSIONAL="price_professional_monthly"
STRIPE_PRICE_ENTERPRISE="price_enterprise_monthly"

# ============================================================================
# LLM PROVIDERS
# ============================================================================
# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# Google AI
GOOGLE_AI_API_KEY="your-google-ai-api-key"

# ============================================================================
# WEBHOOKS
# ============================================================================
# Webhook secret for signature verification
WEBHOOK_SECRET="your-webhook-secret"

# OAuth state secret
OAUTH_STATE_SECRET="your-oauth-state-secret"

# ============================================================================
# LOGGING
# ============================================================================
# Log level (debug, info, warning, error)
TASKBOLT_LOG_LEVEL="info"

# ============================================================================
# MONITORING (Optional)
# ============================================================================
# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_SERVICE_NAME="taskbolt-saas"

# ============================================================================
# INTEGRATIONS (Optional)
# ============================================================================
# Slack
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""

# Discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Microsoft Teams
MICROSOFT_TENANT_ID=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
